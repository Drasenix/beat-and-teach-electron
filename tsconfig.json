{
  "compilerOptions": {
    "incremental": true,
    "target": "es2022",
    "lib": ["es2022"],
    "strict": true,
    "sourceMap": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "outDir": ".erb/dll",
    "moduleResolution": "node"
  },
  "exclude": ["node_modules", "release", "assets"]
}
